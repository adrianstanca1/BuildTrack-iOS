// BuildTrack Production Configuration
// ═══════════════════════════════════════════════════════════
// Used for Release builds targeting the production backend.
// Set this as the project-level xcconfig for Release scheme
// in Xcode: Project → Info → Configurations → Release.
//
// NEVER commit secrets directly here in a real project.
// Consider using a secrets management system or environment
// variables injected at build time. For now, these values
// are compiled directly for production deployment.
// ═══════════════════════════════════════════════════════════

// ── Supabase ──────────────────────────────────────────────
SUPABASE_URL = https://buildtrack.cortexbuildpro.com
SUPABASE_ANON_KEY = sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

// ── API ───────────────────────────────────────────────────
API_BASE_URL = https://buildtrack.cortexbuildpro.com/api

// ── App Metadata ──────────────────────────────────────────
PRODUCT_BUNDLE_IDENTIFIER = ro.stancainvest.buildtrack
PRODUCT_NAME = BuildTrack
PRODUCT_DISPLAY_NAME = BuildTrack

// ── Build Settings Overrides ──────────────────────────────
IPHONEOS_DEPLOYMENT_TARGET = 18.0
SWIFT_VERSION = 6.0
ENABLE_BITCODE = NO
GCC_OPTIMIZATION_LEVEL = s
SWIFT_OPTIMIZATION_LEVEL = -O
SWIFT_COMPILATION_MODE = wholemodule
VALIDATE_PRODUCT = YES
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym

// ── Code Signing (set per-environment) ────────────────────
DEVELOPMENT_TEAM = 4G3G5MX9BH
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = iPhone Distribution
PROVISIONING_PROFILE_SPECIFIER = ""
